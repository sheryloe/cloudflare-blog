---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { getTagMap } from "../../../lib/content";

export async function getStaticPaths() {
  const languages = ["ko", "en"] as const;
  const paths = [];

  for (const lang of languages) {
    const tagMap = await getTagMap(lang);

    for (const tag of tagMap.keys()) {
      paths.push({
        params: { lang, tag },
        props: { posts: tagMap.get(tag) ?? [], lang, tag },
      });
    }
  }

  return paths;
}

const { posts, lang, tag } = Astro.props;
---
<BaseLayout title={`#${tag}`} description={`${tag} 관련 글`} pathname={`/${lang}/tags/${tag}/`}>
  <section class="taxonomy-hero">
    <p class="eyebrow">Tag</p>
    <h1>#{tag}</h1>
  </section>
  <section class="post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
