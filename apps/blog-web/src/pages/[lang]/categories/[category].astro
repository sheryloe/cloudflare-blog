---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import { getCategoryMap } from "../../../lib/content";

export async function getStaticPaths() {
  const languages = ["ko", "en"] as const;
  const paths = [];

  for (const lang of languages) {
    const categoryMap = await getCategoryMap(lang);

    for (const category of categoryMap.keys()) {
      paths.push({
        params: { lang, category },
        props: { posts: categoryMap.get(category) ?? [], lang, category },
      });
    }
  }

  return paths;
}

const { posts, lang, category } = Astro.props;
---
<BaseLayout title={category} description={`${category} 카테고리 글`} pathname={`/${lang}/categories/${category}/`}>
  <section class="taxonomy-hero">
    <p class="eyebrow">Category</p>
    <h1>{category}</h1>
  </section>
  <section class="post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
